# Copy to .env.local and fill with values from:
# https://supabase.com/dashboard/project/_/settings/api

# Supabase (client-side safe — embedded in browser bundle)
NEXT_PUBLIC_SUPABASE_URL=https://dhiciqvgsslsitamenlr.supabase.co/rest/v1/
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_1Skxg2As5KZ6UxOHZbcsOQ_rR_en6Qg
# Required for matchmaking (admin writes: rooms, match_records, queue removals)
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# AI topic generation gateway timeout (seconds, optional)
# GENERATE_TOPIC_TIMEOUT_SECONDS=75

# Optional: generate typed DB client (run when schema changes):
# npx supabase gen types typescript --project-id YOUR_REF > src/types/supabase-database.types.ts

# Realtime: Dashboard → Database → Publications / Replication
# Enable replication for tables you subscribe to in code, e.g. public.debate_rooms, public.webrtc_signals

# AI Referee Gateway (server-only — NEVER prefix with NEXT_PUBLIC_)
AI_GATEWAY_URL=http://127.0.0.1:3001
AI_GATEWAY_KEY=change_this_to_a_long_random_secret_key

# Dev bypass: set to "true" to skip Supabase auth check on referee proxy routes (local testing only)
# REFEREE_PROXY_SKIP_AUTH=true
# Live check fallback: in dev, return empty events when gateway is unreachable.
# Set to "false" to surface 502 errors instead.
# REFEREE_LIVE_CHECK_ALLOW_FALLBACK=true

# If you see "__webpack_modules__[moduleId] is not a function" in dev: stop all Node processes,
# run `npm run clean`, then `npm run dev` (uses Turbopack). Fallback: `npm run dev:webpack`.
